{
  "name": "workshop-repairs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -F nextjs build",
    "clean": "turbo clean && rm -rf .turbo node_modules .sst coverage",
    "commitlint": "commitlint --edit",
    "db": "drizzle-kit",
    "db:migrate": "pnpm -F db db:migrate",
    "db:reset": "pnpm -F db db:reset",
    "db:seed": "pnpm -F db db:seed",
    "db:sequence": "pnpm -F db db:sequence",
    "dev": "turbo dev",
    "format": "prettier . --write",
    "lint": "turbo lint",
    "prepare": "husky",
    "start": "pnpm -F nextjs start",
    "test": "pnpm vitest run",
    "test:coverage": "pnpm vitest run --coverage",
    "test:e2e": "pnpm -F e2e test:e2e",
    "test:gen": "pnpm -F e2e test:gen",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@repo/eslint-config": "workspace:*",
    "@types/aws-lambda": "^8.10.156",
    "@vitest/coverage-v8": "^4.0.3",
    "commitizen": "^4.3.1",
    "commitlint": "^20.1.0",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.38.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "semantic-release": "^25.0.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.3"
  },
  "packageManager": "pnpm@10.19.1-oidc-test.3+sha512.e5961a4b56bb37620f97b65da4ca56216634bf39ed358eda925f0f036534d458fa249d93ed0021410523f8bb7ed8512b61fe5532ed3e81777793366c6be026b5"
}

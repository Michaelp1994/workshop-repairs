{
  "name": "workshop-repairs",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "aws:login": "aws sso login --profile workshop-repairs",
    "build": "turbo build",
    "clean": "turbo clean && rm -rf .turbo node_modules .sst coverage",
    "commitlint": "commitlint --edit",
    "seed": "dotenv turbo seed",
    "dev": "dotenv turbo dev",
    "format": "prettier . --write",
    "lint": "turbo lint",
    "test:coverage": "pnpm vitest run --coverage",
    "test:e2e": "pnpm -F e2e test:e2e",
    "test:gen": "pnpm -F e2e test:gen",
    "test": "pnpm vitest run",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@repo/eslint-config": "workspace:*",
    "@types/aws-lambda": "^8.10.162",
    "@vitest/coverage-v8": "^4.1.9",
    "commitizen": "^4.3.2",
    "commitlint": "^21.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "semantic-release": "^25.0.5",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}

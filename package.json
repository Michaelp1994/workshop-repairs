{
  "name": "workshop-repairs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean && rm -rf .turbo node_modules .sst coverage",
    "commitlint": "commitlint --edit",
    "db:migrate": "pnpm -F db db:migrate",
    "db:reset": "pnpm -F db db:reset",
    "db:seed": "pnpm -F db db:seed",
    "db:sequence": "pnpm -F db db:sequence",
    "dev": "turbo dev",
    "format": "prettier . --write",
    "lint": "turbo lint",
    "prepare": "husky",
    "start": "turbo start",
    "test": "pnpm vitest run",
    "test:coverage": "pnpm vitest run --coverage",
    "test:e2e": "pnpm -F e2e test:e2e",
    "test:gen": "pnpm -F e2e test:gen",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@repo/eslint-config": "workspace:*",
    "@types/aws-lambda": "^8.10.156",
    "@vitest/coverage-v8": "^4.0.4",
    "commitizen": "^4.3.1",
    "commitlint": "^20.1.0",
    "eslint": "^9.38.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "semantic-release": "^25.0.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.4"
  },
  "packageManager": "pnpm@10.20.0+sha512.cf9998222162dd85864d0a8102e7892e7ba4ceadebbf5a31f9c2fce48dfce317a9c53b9f6464d1ef9042cba2e02ae02a9f7c143a2b438cd93c91840f0192b9dd"
}

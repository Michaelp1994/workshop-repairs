{
  "name": "workshop-repairs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -F nextjs build",
    "clean": "turbo clean && rm -rf .turbo node_modules .sst coverage",
    "commitlint": "commitlint --edit",
    "db": "drizzle-kit",
    "db:migrate": "pnpm -F db db:migrate",
    "db:reset": "pnpm -F db db:reset",
    "db:seed": "pnpm -F db db:seed",
    "db:sequence": "pnpm -F db db:sequence",
    "dev": "pnpm -F nextjs dev",
    "format": "prettier . --write",
    "lint": "turbo lint",
    "prepare": "husky",
    "start": "pnpm -F nextjs start",
    "test": "pnpm vitest run",
    "test:coverage": "pnpm vitest run --coverage",
    "test:e2e": "pnpm -F e2e test:e2e",
    "test:gen": "pnpm -F e2e test:gen",
    "typecheck": "turbo typecheck"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@repo/eslint-config": "workspace:*",
    "@types/aws-lambda": "^8.10.149",
    "@vitest/coverage-v8": "^3.1.2",
    "commitizen": "^4.3.1",
    "commitlint": "^19.8.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.26.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "semantic-release": "^24.2.3",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  },
  "packageManager": "pnpm@10.18.3+sha512.bbd16e6d7286fd7e01f6b3c0b3c932cda2965c06a908328f74663f10a9aea51f1129eea615134bf992831b009eabe167ecb7008b597f40ff9bc75946aadfb08d",
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.2",
      "@types/react-dom": "19.1.3"
    }
  }
}

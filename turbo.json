{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["node_modules/.cache/tsbuildinfo.json", "dist/**"]
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "db": {
      "cache": false,
      "persistent": true
    },
    "seed": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "outputs": ["node_modules/.cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^topo", "^build"],
      "outputs": ["node_modules/.cache/.eslintcache"]
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": ["node_modules/.cache/tsbuildinfo.json"]
    },
    "clean": {
      "cache": false
    }
  },
  "globalPassThroughEnv": [
    "NODE_ENV",
    "POSTGRES_*",
    "JWT_SECRET",
    "NODE_ENV",
    "S3_BUCKET_NAME",
    "IMAGE_URL",
    "RETURN_EMAIL",
    "TEST_*",
    "OTLP_*"
  ]
}

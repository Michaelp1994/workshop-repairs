{
  "name": "@repo/db",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./repositories/*": "./src/repositories/*.ts"
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules dist",
    "db": "drizzle-kit",
    "db:seed": "tsx --env-file=.env ./src/seed/seed.ts",
    "dbml:generate": "tsx ./scripts/create-dbml.ts",
    "dbml:render": "dbml-renderer -i schema.dbml -o schema.svg",
    "dev": "drizzle-kit studio",
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.918.0",
    "drizzle-orm": "^0.44.7",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@repo/auth": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/validators": "workspace:*",
    "@softwaretechnik/dbml-renderer": "^1.0.31",
    "@types/node": "^24.9.1",
    "@types/pg": "^8.15.6",
    "drizzle-dbml-generator": "^0.10.0",
    "drizzle-kit": "^0.31.5",
    "drizzle-seed": "^0.3.1",
    "eslint": "^9.38.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.4"
  }
}

{
  "extends": "@repo/typescript-config/internal-package.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "exactOptionalPropertyTypes": false,
    "outDir": "dist",
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json"
  },
  "tsc-alias": {
    "resolveFullPaths": true
  },
  "include": [
    "src",
    "*.config.*",
    "sst-env.d.ts",
    "../../packages/services/src/helpers/includeMetadata.ts",
    "../../packages/services/src/helpers/sendInvitationEmail.ts"
  ],
  "exclude": ["node_modules", "eslint.config.js"]
}
